// ─── STATE ───────────────────────────────────────────────────────────────────
let activeDistrict = "all";
let activeType = "all";
let activeHeritage = "all";
let searchQuery = "";
let selectedId = null;
let markers = {};

// ─── MAP INIT ────────────────────────────────────────────────────────────────
const isDark = () => document.documentElement.getAttribute("data-theme") === "dark";

const lightTiles = "https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png";
const darkTiles  = "https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png";

const map = L.map("map", {
  center: [29.7412, -95.3601],
  zoom: 13,
  zoomControl: true,
});

let tileLayer = L.tileLayer(isDark() ? darkTiles : lightTiles, {
  maxZoom: 19,
  attribution: "© CartoDB"
}).addTo(map);

function updateMapTiles() {
  tileLayer.setUrl(isDark() ? darkTiles : lightTiles);
}

// ─── MARKER CREATION ─────────────────────────────────────────────────────────
function createMarkerIcon(loc) {
  const color = TYPE_COLORS[loc.type] || "#888";
  const icon = TYPE_ICONS[loc.type] || "📍";
  return L.divIcon({
    className: "",
    html: `<div class="custom-marker" style="background:${color};border-color:rgba(255,255,255,0.4);" title="${loc.name}">${icon}</div>`,
    iconSize: [32, 32],
    iconAnchor: [16, 16],
    popupAnchor: [0, -18]
  });
}

function addMarkers() {
  Object.values(markers).forEach(m => map.removeLayer(m));
  markers = {};
  const filtered = getFiltered();
  filtered.forEach(loc => {
    const m = L.marker([loc.lat, loc.lng], { icon: createMarkerIcon(loc) }).addTo(map);
    m.on("click", () => selectLocation(loc.id));
    markers[loc.id] = m;
  });
  document.getElementById("map-count").textContent = filtered.length;
  document.getElementById("total-count").textContent = filtered.length;
}

// ─── FILTERING ───────────────────────────────────────────────────────────────
function getFiltered() {
  return locations.filter(loc => {
    const matchDist = activeDistrict === "all" || loc.district === activeDistrict;
    const matchType = activeType === "all" || loc.type === activeType;
    const matchHeritage = activeHeritage === "all" || loc.heritage === activeHeritage;
    const matchSearch = !searchQuery || 
      loc.name.toLowerCase().includes(searchQuery) ||
      loc.district.toLowerCase().includes(searchQuery) ||
      loc.type.toLowerCase().includes(searchQuery) ||
      (loc.desc || "").toLowerCase().includes(searchQuery);
    return matchDist && matchType && matchHeritage && matchSearch;
  });
}

// ─── RESULTS LIST ────────────────────────────────────────────────────────────
function renderList() {
  const filtered = getFiltered();
  const container = document.getElementById("results-list-container");
  document.getElementById("results-count-label").textContent = 
    `Showing ${filtered.length} of ${locations.length} locations`;

  if (filtered.length === 0) {
    container.innerHTML = `<div class="empty-state">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <p>No locations match your filters. Try adjusting your search.</p>
    </div>`;
    return;
  }

  container.innerHTML = filtered.map(loc => {
    const distColor = DISTRICTS[loc.district]?.color || "#888";
    const typeColor = TYPE_COLORS[loc.type] || "#888";
    const isSelected = loc.id === selectedId;
    return `<div class="result-card ${isSelected ? "selected" : ""}" data-id="${loc.id}" onclick="selectLocation(${loc.id})">
      <div class="result-card-header">
        <div class="result-name">${loc.name}</div>
        <span class="result-type-badge" style="background:${typeColor}22;color:${typeColor};border:1px solid ${typeColor}44">${TYPE_ICONS[loc.type] || ""} ${loc.type}</span>
      </div>
      <div class="result-district">
        <span class="result-district-dot" style="background:${distColor}"></span>
        ${loc.district}
      </div>
      <div class="result-meta">${loc.address}</div>
    </div>`;
  }).join("");
}

// ─── DETAIL PANEL ────────────────────────────────────────────────────────────
function selectLocation(id) {
  selectedId = id;
  const loc = locations.find(l => l.id === id);
  if (!loc) return;

  renderList();

  const distColor = DISTRICTS[loc.district]?.color || "#888";
  const typeColor = TYPE_COLORS[loc.type] || "#888";

  document.getElementById("detail-name").textContent = loc.name;
  document.getElementById("detail-badge").textContent = `${TYPE_ICONS[loc.type] || ""} ${loc.type}`;
  document.getElementById("detail-badge").style.cssText = 
    `background:${typeColor}22;color:${typeColor};border:1px solid ${typeColor}44;font-size:var(--text-xs);font-weight:600;padding:2px 10px;border-radius:var(--radius-full);`;
  document.getElementById("detail-district").innerHTML = 
    `<span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${distColor};margin-right:4px;"></span>${loc.district}`;

  document.getElementById("detail-body").innerHTML = `
    ${loc.desc ? `<div class="detail-row">
      <svg class="detail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/></svg>
      <div class="detail-row-content"><div class="detail-row-value" style="font-size:var(--text-xs);color:var(--color-text-muted);line-height:1.5">${loc.desc}</div></div>
    </div>` : ""}
    <div class="detail-row">
      <svg class="detail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0z"/></svg>
      <div class="detail-row-content">
        <div class="detail-row-label">Address</div>
        <div class="detail-row-value">${loc.address}</div>
      </div>
    </div>
    ${loc.hours ? `<div class="detail-row">
      <svg class="detail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
      <div class="detail-row-content">
        <div class="detail-row-label">Hours</div>
        <div class="detail-row-value">${loc.hours}</div>
      </div>
    </div>` : ""}
    <div class="detail-row">
      <svg class="detail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253"/></svg>
      <div class="detail-row-content">
        <div class="detail-row-label">Website</div>
        <div class="detail-row-value"><a href="${loc.website}" target="_blank" rel="noopener noreferrer">${loc.website.replace("https://","").replace("http://","")}</a></div>
      </div>
    </div>
    ${loc.heritage && loc.heritage !== "Multicultural" ? `<div class="detail-row">
      <svg class="detail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21"/></svg>
      <div class="detail-row-content">
        <div class="detail-row-label">Heritage Focus</div>
        <div class="detail-row-value">${loc.heritage}</div>
      </div>
    </div>` : ""}
  `;

  document.getElementById("detail-actions").innerHTML = `
    <a href="${loc.website}" target="_blank" rel="noopener noreferrer" class="btn-primary">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      Visit Website
    </a>
    ${loc.events ? `<a href="${loc.events}" target="_blank" rel="noopener noreferrer" class="btn-secondary">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      Events
    </a>` : ""}
  `;

  const panel = document.getElementById("detail-panel");
  panel.classList.add("visible");

  map.flyTo([loc.lat, loc.lng], 15, { duration: 0.8 });
}

document.getElementById("detail-close").addEventListener("click", () => {
  document.getElementById("detail-panel").classList.remove("visible");
  selectedId = null;
  renderList();
});

// ─── FILTER LOGIC ────────────────────────────────────────────────────────────
function setupFilters(groupId, stateKey) {
  document.getElementById(groupId).addEventListener("click", e => {
    const chip = e.target.closest(".chip");
    if (!chip) return;
    document.querySelectorAll(`#${groupId} .chip`).forEach(c => c.classList.remove("active"));
    chip.classList.add("active");
    if (stateKey === "district") activeDistrict = chip.dataset.value;
    if (stateKey === "type") activeType = chip.dataset.value;
    if (stateKey === "heritage") activeHeritage = chip.dataset.value;
    refresh();
  });
}

setupFilters("district-filters", "district");
setupFilters("type-filters", "type");
setupFilters("heritage-filters", "heritage");

document.getElementById("search-input").addEventListener("input", e => {
  searchQuery = e.target.value.toLowerCase().trim();
  refresh();
});

function refresh() {
  addMarkers();
  renderList();
}

// ─── THEME TOGGLE ────────────────────────────────────────────────────────────
(function(){
  const t = document.querySelector("[data-theme-toggle]");
  const r = document.documentElement;
  let d = matchMedia("(prefers-color-scheme:dark)").matches ? "dark" : "light";
  r.setAttribute("data-theme", d);
  updateMapTiles();
  function updateIcon() {
    if (!t) return;
    t.innerHTML = d === "dark"
      ? '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>'
      : '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
  }
  updateIcon();
  if (t) t.addEventListener("click", () => {
    d = d === "dark" ? "light" : "dark";
    r.setAttribute("data-theme", d);
    updateMapTiles();
    updateIcon();
  });
})();

// ─── INIT ────────────────────────────────────────────────────────────────────
addMarkers();
renderList();

// Resize map on layout changes
window.addEventListener("resize", () => map.invalidateSize());
setTimeout(() => map.invalidateSize(), 200);
</script>
